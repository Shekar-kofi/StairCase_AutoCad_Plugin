<Window x:Class="StaircaseDetails.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Staircase Details" Height="800" Width="1000" SizeToContent="WidthAndHeight" MaxWidth="1200" MaxHeight="800">
 <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
 <StackPanel Margin="10" VerticalAlignment="Top">

 <!-- Staircase Number -->
 <StackPanel Orientation="Horizontal" Margin="0,2">
 <TextBlock Text="Staircase Number (e.g., '01', '02B'):" Width="250" VerticalAlignment="Center" />
 <TextBox Name="StaircaseNumberTextBox" Width="100" />
 </StackPanel>

 <!-- Riser, Tread, Waist Thickness, Stair Width -->
 <StackPanel Orientation="Horizontal" Margin="0,2">
 <TextBlock Text="Riser (mm):" Width="150" VerticalAlignment="Center" />
 <TextBox Name="RiserTextBox" Width="80" />
 </StackPanel>

 <StackPanel Orientation="Horizontal" Margin="0,2">
 <TextBlock Text="Tread (mm):" Width="150" VerticalAlignment="Center" />
 <TextBox Name="TreadTextBox" Width="80" />
 </StackPanel>

 <StackPanel Orientation="Horizontal" Margin="0,2">
 <TextBlock Text="Waist Thickness (mm):" Width="150" VerticalAlignment="Center" />
 <TextBox Name="WaistThicknessTextBox" Width="80" PreviewTextInput="IntegerOnlyInput" />
 </StackPanel>

 <StackPanel Orientation="Horizontal" Margin="0,2">
 <TextBlock Text="Stair Width (mm):" Width="150" VerticalAlignment="Center" />
 <TextBox Name="StairWidthTextBox" Width="80" />
 </StackPanel>

 <!-- Floor Names -->
 <StackPanel Orientation="Horizontal" Margin="0,2">
 <TextBlock Text="Bottom Floor Name:" Width="150" VerticalAlignment="Center" />
 <TextBox Name="BottomFloorNameTextBox" Width="250" />
 </StackPanel>

 <StackPanel Orientation="Horizontal" Margin="0,2">
 <TextBlock Text="Top Floor Name:" Width="150" VerticalAlignment="Center" />
 <TextBox Name="TopFloorNameTextBox" Width="250" />
 </StackPanel>

 <!-- Floor Height -->
 <StackPanel Orientation="Horizontal" Margin="0,2">
 <TextBlock Text="Floor Height (mm):" Width="150" VerticalAlignment="Center" />
 <TextBox Name="FloorHeightTextBox" Width="80" PreviewTextInput="IntegerOnlyInput" />
 </StackPanel>

 <!-- Ground Floor Checkbox -->
 <CheckBox Name="GroundFloorCheckBox" Content="Ground Floor?" Checked="GroundFloorCheckBox_Checked" Unchecked="GroundFloorCheckBox_Unchecked" Margin="0,2" />

 <!-- Support Options -->
 <StackPanel Name="SupportOptionsPanel" Visibility="Collapsed" Margin="20,0,0,0">
 <TextBlock Text="Support Type:" />
 <CheckBox Name="BeamSupportCheckBox" Content="Beam Support" Checked="SupportType_Checked" Unchecked="SupportType_Unchecked" />
 <CheckBox Name="SlabThickeningCheckBox" Content="Slab Thickening" Checked="SupportType_Checked" Unchecked="SupportType_Unchecked" />
 </StackPanel>

 <!-- Staircase Type -->
 <TextBlock Text="Staircase Type:" />
 <CheckBox Name="HalfTurnCheckBox" Content="Half Turn" Checked="StaircaseType_Checked" Unchecked="StaircaseType_Unchecked" />
 <CheckBox Name="QuarterTurnCheckBox" Content="Quarter Turn" Checked="StaircaseType_Checked" Unchecked="StaircaseType_Unchecked" />

 <!-- Number of Flights -->
 <StackPanel Orientation="Horizontal" Margin="0,2">
 <TextBlock Text="Number of Flights / Turns:" Width="150" VerticalAlignment="Center" />
 <ComboBox Name="FlightsComboBox" SelectionChanged="FlightsComboBox_SelectionChanged" Width="80">
 <ComboBoxItem Content="2" />
 <ComboBoxItem Content="3" />
 </ComboBox>
 </StackPanel>

 <!-- Dynamic Flight Sections -->
 <StackPanel Name="FlightsPanel" Orientation="Horizontal" />

 <!-- Orientation of First Flight -->
 <StackPanel Orientation="Horizontal" Margin="0,2">
 <TextBlock Text="Orientation of First Flight:" Width="150" VerticalAlignment="Center" />
 <ComboBox Name="OrientationComboBox" Width="150">
 <ComboBoxItem Content="Left to Right" />
 <ComboBoxItem Content="Right to Left" />
 </ComboBox>
 </StackPanel>

 </StackPanel>
 </ScrollViewer>
</Window>