namespace StaircaseDetails
{
    public class StaircaseClass
    {

        [CommandMethod("StaircaseDetails")]
        public static void StaircaseDetails()
        {
            Document doc = Application.DocumentManager.MdiActiveDocument;
            Database db = doc.Database;
            Editor ed = doc.Editor;

            short oldOrtho = 0;
            short oldOsnap = 0;


            try
            {
                //turn ortho and object snap off for smooth selection
                //at the end, will restore the states of the modes
                oldOrtho = (short)Application.GetSystemVariable("ORTHOMODE");
                oldOsnap = (short)Application.GetSystemVariable("OSMODE");


                // --- Turn modes off for smooth picking ---
                Application.SetSystemVariable("ORTHOMODE", 0);
                Application.SetSystemVariable("OSMODE", 0);







            }
            catch (System.Exception ex)
            {
                ed.WriteMessage("\nError in nStaircaseDetails: " + ex.Message + ": " + ex.StackTrace);
            }
            finally
            {
                //restore ortho and osnap modes
                Application.SetSystemVariable("ORTHOMODE", oldOrtho);
                Application.SetSystemVariable("OSMODE", oldOsnap);
            }



        }
    }
}
