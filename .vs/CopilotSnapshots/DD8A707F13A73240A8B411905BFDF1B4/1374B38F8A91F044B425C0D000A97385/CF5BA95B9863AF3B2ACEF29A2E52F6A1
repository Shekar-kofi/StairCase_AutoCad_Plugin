<Window x:Class="StaircaseDetails.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Staircase Details" Height="800" Width="600">
 <ScrollViewer VerticalScrollBarVisibility="Auto">
 <StackPanel Margin="10" VerticalAlignment="Top">

 <!-- Staircase Number -->
 <TextBlock Text="Staircase Number (e.g., '01', '02B'):" />
 <TextBox Name="StaircaseNumberTextBox" Width="200" />

 <!-- Riser, Tread, Waist Thickness, Stair Width -->
 <TextBlock Text="Riser (mm):" />
 <TextBox Name="RiserTextBox" Width="150" />

 <TextBlock Text="Tread (mm):" />
 <TextBox Name="TreadTextBox" Width="150" />

 <TextBlock Text="Waist Thickness (mm):" />
 <TextBox Name="WaistThicknessTextBox" Width="150" PreviewTextInput="IntegerOnlyInput" />

 <TextBlock Text="Stair Width (mm):" />
 <TextBox Name="StairWidthTextBox" Width="150" />

 <!-- Floor Names -->
 <TextBlock Text="Bottom Floor Name:" />
 <TextBox Name="BottomFloorNameTextBox" Width="250" />

 <TextBlock Text="Top Floor Name:" />
 <TextBox Name="TopFloorNameTextBox" Width="250" />

 <!-- Floor Height -->
 <TextBlock Text="Floor Height (mm):" />
 <TextBox Name="FloorHeightTextBox" Width="150" PreviewTextInput="IntegerOnlyInput" />

 <!-- Ground Floor Checkbox -->
 <CheckBox Name="GroundFloorCheckBox" Content="Ground Floor?" Checked="GroundFloorCheckBox_Checked" Unchecked="GroundFloorCheckBox_Unchecked" />

 <!-- Support Options -->
 <StackPanel Name="SupportOptionsPanel" Visibility="Collapsed" Margin="20,0,0,0">
 <TextBlock Text="Support Type:" />
 <CheckBox Name="BeamSupportCheckBox" Content="Beam Support" Checked="SupportType_Checked" Unchecked="SupportType_Unchecked" />
 <CheckBox Name="SlabThickeningCheckBox" Content="Slab Thickening" Checked="SupportType_Checked" Unchecked="SupportType_Unchecked" />
 </StackPanel>

 <!-- Staircase Type -->
 <TextBlock Text="Staircase Type:" />
 <CheckBox Name="HalfTurnCheckBox" Content="Half Turn" Checked="StaircaseType_Checked" />
 <CheckBox Name="QuarterTurnCheckBox" Content="Quarter Turn" Checked="StaircaseType_Checked" />

 <!-- Number of Flights -->
 <TextBlock Text="Number of Flights / Turns:" />
 <ComboBox Name="FlightsComboBox" SelectionChanged="FlightsComboBox_SelectionChanged">
 <ComboBoxItem Content="2" />
 <ComboBoxItem Content="3" />
 </ComboBox>

 <!-- Dynamic Flight Sections -->
 <StackPanel Name="FlightsPanel" />

 <!-- Orientation of First Flight -->
 <TextBlock Text="Orientation of First Flight:" />
 <ComboBox Name="OrientationComboBox">
 <ComboBoxItem Content="Left to Right" />
 <ComboBoxItem Content="Right to Left" />
 </ComboBox>

 </StackPanel>
 </ScrollViewer>
</Window>